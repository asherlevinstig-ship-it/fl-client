{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "node",
    "sourceMap": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "types": ["vite/client", "node"],
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}